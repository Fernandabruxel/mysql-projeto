<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Produtos</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="container">
    <header>
      <h1>Catálogo de Produtos</h1>
      <a class="btn" href="/produtos/novo">Novo Produto</a>
    </header>

    <div class="grid">
      <% produtos.forEach(produto => { %>
        <div class="card">
          <h2><%= produto.nome %></h2>
          <p><%= produto.descricao %></p>

          <p><strong>Categoria:</strong> <%= produto.categoria %></p>
          <p><strong>Preço:</strong> R$ <%= produto.preco %></p>
          <p><strong>Estoque:</strong> <%= produto.estoque %></p>

          <h3>Atributos</h3>

          <% if (produto.atributos) { %>
            <% for (let [chave, valor] of produto.atributos) { %>
              <p><strong><%= chave %>:</strong> <%= valor %></p>
            <% } %>
          <% } %>

          <div class="acoes">
            <a href="/produtos/editar/<%= produto._id %>">Editar</a>

            <form action="/produtos/deletar/<%= produto._id %>" method="POST">
              <button class="danger" type="submit">Excluir</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

</body>
</html>